flowchart TD
  %% Episode 1 - Deterministic core design
  %% Legend: solid = deterministic transform/call, dashed = emitted intent

  In[PhysicalCarVocabulary / FsmEvent input] --> Step["step(current_state, current_ctx, event, now)"]
  Step --> Ctx[modified_ctx]
  Step --> Ns[next_state]
  Step --> Tr[transition_record]
  Step -. emits .-> Act[actions: Vec<DomainAction>]

  subgraph Runtime[Runtime-Owned Execution]
    Exec[Action execution in controller/runtime]
    Mode[Actor mode decision]
  end

  Act -. intent only, no direct I/O .-> Exec
  Act -. EnterMode hint .-> Mode

  subgraph Contracts[Test Contracts]
    C1[fsm_step_contract]
    C2[lighting_step_contract]
    C3[projection_contract]
  end

  Step --> C1
  Step --> C2
  In --> C3

