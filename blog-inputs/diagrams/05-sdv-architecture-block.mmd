flowchart TB
    %% SDV simulation — system block diagram (arrows only, no message labels)
    %% View/edit: https://mermaid.live or any Mermaid-capable Markdown preview

    subgraph CAN["SocketCAN · vcan0"]
        BUS(( ))
    end

    subgraph emulator["emulator"]
        EMU[Physical world models<br/>RPM · ambient lux]
    end

    subgraph front_headlamp_actuator["front_headlamp_actuator"]
        ACT[Actuator loop]
    end

    subgraph gateway["gateway"]
        CAN_RX[CAN reader thread]
        ING[Ingress mapping]
        PROJ[Physical → digital projection]
        VC[VehicleController]
        TICK[Timer tick loop]
        POL[Front-headlamp policy]
        CMD_TX[CMD frame publisher]

        subgraph DT["Digital Twin"]
            ACTOR[VirtualCarActor]

            subgraph FSM["FSM"]
                STEP[step]
                TM[transition_map]
                VK[vehicle_kinematics]
                TH[vehicle_constants]
            end

            TWIN[(DigitalTwinCar<br/>FsmState · VehicleContext)]
            AM[ActuationManager]
        end
    end

    subgraph vehicle_device_bus["vehicle_device_bus · shared library"]
        WIRE[CAN codec · wire kinds]
        FPOL[front_headlamp policy helpers]
    end

    EMU --> BUS
    BUS --> CAN_RX
    CAN_RX --> ING
    ING --> PROJ
    PROJ --> VC
    VC --> ACTOR
    ACTOR --> STEP
    STEP --> TM
    STEP --> VK
    STEP --> TH
    STEP --> TWIN
    TWIN --> STEP
    ACTOR --> AM
    AM --> CMD_TX
    CMD_TX --> BUS
    BUS --> ACT
    ACT --> BUS
    BUS --> CAN_RX
    TICK --> VC
    POL --- CAN_RX
    WIRE -.-> gateway
    FPOL -.-> POL
