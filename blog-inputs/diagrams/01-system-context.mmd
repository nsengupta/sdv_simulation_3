flowchart LR
  %% Episode 1 - System context
  %% Legend: solid = sync call/data transfer, dashed = async/event stream

  subgraph Ext[External Systems]
    Emu[Emulator]
    CAN[(SocketCAN vcan0)]
    Cloud[(Cloud / Observer)]
  end

  subgraph Gtw[Gateway Crate]
    GR[Gateway Runtime]
  end

  subgraph Common[Common Crate]
    VC[VehicleController]
    VA[VirtualCarActor]
    Core[FSM step() + Domain Core]
    AM[ActuationManager]
  end

  Emu -. VehicleEvent telemetry .-> CAN
  CAN --> GR
  GR --> VC
  VC --> VA
  VA --> Core
  Core -. DomainAction: PublishStateSync .-> Cloud
  Core -. DomainAction: RequestFrontHeadlampOn/Off .-> AM
  AM -. ActuationCommand .-> GR
  GR -. command/response frames .-> CAN

  classDef ext fill:#eef7ff,stroke:#1f6feb,color:#0b1f44;
  classDef gtw fill:#fff7e6,stroke:#b7791f,color:#4a2f00;
  classDef common fill:#ecfff4,stroke:#238636,color:#0b2f1a;
  class Emu,CAN,Cloud ext;
  class GR gtw;
  class VC,VA,Core,AM common;
