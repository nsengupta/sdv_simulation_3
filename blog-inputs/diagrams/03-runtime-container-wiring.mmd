flowchart LR
  %% Episode 2 - Runtime/container wiring
  %% Legend: solid = direct call, dashed = async message/channel

  subgraph Transport[Transport Boundary]
    Sock[(CanSocket read_frame loop)]
    Bus[(CAN bus)]
  end

  subgraph Gateway[Gateway Runtime]
    Reader[CAN Reader Thread]
    Ingress[Ingress Mapping]
    Tick[TimerTick Loop]
    Disp[Ingress Dispatch Loop]
    Router[Front-Headlamp Command Router]
    Actuator[front_headlamp_actuator · legacy in-gateway]
    Policy[FrontHeadlampPolicy]
  end

  subgraph Domain[Common Runtime]
    Ctl[VehicleController]
    Actor[VirtualCarActor]
    Core[FSM step()]
    ActMgr[ActuationManager]
  end

  Bus --> Sock --> Reader
  Reader --> Ingress --> Disp --> Ctl
  Tick -. VehicleEvent::TimerTick .-> Ctl
  Ctl --> Actor --> Core
  Core -. DomainAction .-> ActMgr
  ActMgr -. ActuationCommand tx .-> Router
  Router --> Policy
  Router -. command channel .-> Actuator
  Actuator -. ACK/NACK/No-response frames .-> Bus
  Reader --> Policy
  Policy -. accepted actuation response .-> Disp

  classDef transport fill:#eef7ff,stroke:#1f6feb,color:#0b1f44;
  classDef gateway fill:#fff7e6,stroke:#b7791f,color:#4a2f00;
  classDef domain fill:#ecfff4,stroke:#238636,color:#0b2f1a;
  class Sock,Bus transport;
  class Reader,Ingress,Tick,Disp,Router,Actuator,Policy gateway;
  class Ctl,Actor,Core,ActMgr domain;
